# =============================================
# DATABASE — PostgreSQL (required)
# =============================================
# Supported providers: Neon, Supabase, Railway, Render, local Docker
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/interntrack?schema=public

# =============================================
# AUTHENTICATION (required in production)
# =============================================
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-very-long-random-secret-here-replace-this

# =============================================
# AI FEATURES — Google Gemini (optional)
# =============================================
# Get your key at: https://aistudio.google.com/app/apikey
# AI features gracefully fall back to high-quality static responses if key is absent.
GEMINI_API_KEY=your-gemini-api-key-here
